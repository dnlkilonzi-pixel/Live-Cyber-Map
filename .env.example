# Database
DATABASE_URL=postgresql+asyncpg://cybermap:cybermap_dev@localhost:5432/cybermap
POSTGRES_PASSWORD=cybermap_dev

# Redis
REDIS_URL=redis://localhost:6379

# Backend Settings
EVENTS_PER_SECOND=50
MAX_EVENTS_HISTORY=1000
CORS_ORIGINS=["http://localhost:3000","http://localhost:80"]

# Ollama (local AI model server – no external API key required)
# Install Ollama from https://ollama.ai, then run: ollama pull llama3.2:3b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Frontend
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_OLLAMA_URL=http://localhost:11434

# Tauri desktop build – Ed25519 signing keys for auto-update.
# Generate with: tauri signer generate -w ~/.tauri/update-key.key
# Copy the printed public key below and add the file contents as TAURI_PRIVATE_KEY secret in GitHub.
# TAURI_PRIVATE_KEY=<base64-encoded-public-key>
# TAURI_KEY_PASSWORD=<optional-key-password>

# Tauri desktop build – override the backend URL for embedded / remote deployments.
# The Rust side reads VITE_API_URL (Vite projects) or NEXT_PUBLIC_API_URL.
# VITE_API_URL=http://localhost:8000

# Playwright E2E tests – set to your deployed URL to run against the live site,
# or leave unset to spin up a local Next.js server for CI.
# BASE_URL=https://your-deployment.vercel.app

# OpenAPI client generation (npm run generate:api)
# Requires the backend to be running locally.
# Outputs to frontend/types/api.d.ts – commit this file after each schema change.
