# Database
DATABASE_URL=postgresql+asyncpg://cybermap:cybermap_dev@localhost:5432/cybermap
POSTGRES_PASSWORD=cybermap_dev

# Redis
REDIS_URL=redis://localhost:6379

# Backend Settings
EVENTS_PER_SECOND=50
MAX_EVENTS_HISTORY=1000
CORS_ORIGINS=["http://localhost:3000","http://localhost:80"]

# Ollama (local AI model server – no external API key required)
# Install Ollama from https://ollama.ai, then run: ollama pull llama3.2:3b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Frontend
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_API_URL=http://localhost:8000
